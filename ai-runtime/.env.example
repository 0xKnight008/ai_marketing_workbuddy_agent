# ---- LLM ----
# AI SDK model id, e.g. openai/gpt-4o-mini, anthropic/claude-sonnet-4-5, google/gemini-2.5-flash
AI_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=

# ---- Internal API ----
# Shared secret between run-service and ai-runtime. Required in production.
INTERNAL_API_TOKEN=dev-internal-token

# ---- Run Service callback ----
# The only event callback destination. Per-request callback URLs are intentionally unsupported.
RUN_SERVICE_CALLBACK_URL=http://localhost:4102/internal/ai-runtime-events
# HMAC secret used to sign event callbacks (optional but recommended)
EVENT_CALLBACK_SIGNING_SECRET=
# Event delivery retry policy
EVENT_CALLBACK_MAX_RETRIES=3
EVENT_CALLBACK_TIMEOUT_MS=5000

# ---- Server ----
PORT=4111
# Mastra Studio 只允许指向 staging（见架构文档 §12.5）
MASTRA_STUDIO_ENABLED=false

# ---- Storage ----
# Local development uses file; production must use a shared LibSQL endpoint.
MASTRA_STORAGE_URL=file:./mastra.db
# Required by authenticated remote LibSQL providers such as Turso.
MASTRA_STORAGE_AUTH_TOKEN=
# Retain terminal polling records for 24 hours.
RUN_REGISTRY_RETENTION_MS=86400000
